#!/bin/bash
## Description: Run bunx commands in the Books theme directory
## Usage: books:bunx <bunx-command> [args]
## Example: "ddev books:bunx vite build"

if [ ! -d "/var/www/html/web/themes/custom/books" ]; then
    echo "Error: Theme 'books' not found in web/themes/custom/"
    exit 1
fi
cd /var/www/html/web/themes/custom/books || exit
exec bunx "$@"
